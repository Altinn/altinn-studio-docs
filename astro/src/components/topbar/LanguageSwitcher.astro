---
import { site } from "@lib/site";
import { t } from "@lib/i18n";

interface Props {
  lang: string;
}
const { lang } = Astro.props;
const otherLangs = site.languages.filter((l) => l !== lang);
const path = Astro.url.pathname;

function swapLang(p: string, from: string, to: string) {
  // /nb/foo/ → /en/foo/
  return p.replace(new RegExp(`^/${from}(/|$)`), `/${to}$1`);
}
---

<div class="language-switcher" aria-label={t("Language", lang)}>
  {otherLangs.map((l) => (
    <a href={swapLang(path, lang, l)} hreflang={l} class="lang-link">
      {l.toUpperCase()}
    </a>
  ))}
</div>

<style>
  .language-switcher {
    display: flex;
    gap: 0.5rem;
  }
  .lang-link {
    color: white;
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 3px;
    font-size: 0.85rem;
  }
  .lang-link:hover {
    background: rgba(255, 255, 255, 0.15);
  }
</style>
