---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import SearchBox from "./SearchBox.astro";
import { t } from "@lib/i18n";

interface Props {
  lang: string;
}
const { lang } = Astro.props;
---

<header class="a-header">
  <nav class="a-jumpnav">
    <a class="sr-only sr-only-focusable" href="#content">{t("jump-to-main-content", lang)}</a>
  </nav>
  <div class="container">
    <div class="topbar-row">
      <a href={`/${lang}/`} class="logo-link" aria-label={t("to-the-frontpage", lang)}>
        <img src="/images/adocs-logo-white.svg" alt="Altinn" class="topbar-logo" />
      </a>
      <div class="topbar-actions">
        <SearchBox lang={lang} />
        <LanguageSwitcher lang={lang} />
      </div>
    </div>
  </div>
</header>

<style>
  .a-header {
    background: var(--c-altinn-blue);
    color: white;
    padding: 0.75rem 0;
  }
  .topbar-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    justify-content: space-between;
  }
  .topbar-logo {
    height: 32px;
  }
  .topbar-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .a-jumpnav {
    position: absolute;
    left: -9999px;
  }
  .sr-only-focusable:focus {
    position: static;
  }
</style>
