---
import { t } from "@lib/i18n";

interface Props {
  lang: string;
}
const { lang } = Astro.props;
---

<div class="search-box">
  <button
    type="button"
    class="search-toggle"
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="search-panel"
    aria-label={t("search", lang)}
  >
    <svg
      width="20"
      height="20"
      viewBox="0 0 20 20"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="2" />
      <line x1="13.5" y1="13.5" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    </svg>
  </button>
  <div id="search-panel" class="search-panel" hidden>
    <input
      type="search"
      id="search-input"
      placeholder={t("search", lang)}
      aria-label={t("search", lang)}
    />
    <div id="search-results" class="search-results" hidden></div>
  </div>
</div>

<script>
  // Pagefind blir lastet inn lazy fra dist/pagefind/pagefind.js etter build.
  // Vi bygger URL-en dynamisk slik at Vite ikke prøver å resolve compile-time.
  let pagefind: any = null;
  let initStarted = false;

  async function ensurePagefind(input: HTMLInputElement) {
    if (initStarted) return pagefind;
    initStarted = true;
    try {
      const url = `${window.location.origin}/pagefind/pagefind.js`;
      const head = await fetch(url, { method: "HEAD" });
      if (!head.ok) throw new Error("not built");
      pagefind = await import(/* @vite-ignore */ url);
      await pagefind.init();
    } catch {
      input.placeholder = "Tilgjengelig etter build";
      input.disabled = true;
    }
    return pagefind;
  }

  const root = document.querySelector(".search-box") as HTMLElement | null;
  if (root) {
    const btn = root.querySelector(".search-toggle") as HTMLButtonElement;
    const panel = root.querySelector(".search-panel") as HTMLElement;
    const input = root.querySelector("#search-input") as HTMLInputElement;
    const results = root.querySelector("#search-results") as HTMLElement;

    btn.addEventListener("click", async (e) => {
      e.stopPropagation();
      const open = !panel.hidden;
      if (open) {
        panel.hidden = true;
        btn.setAttribute("aria-expanded", "false");
      } else {
        panel.hidden = false;
        btn.setAttribute("aria-expanded", "true");
        await ensurePagefind(input);
        input.focus();
      }
    });
    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) {
        panel.hidden = true;
        btn.setAttribute("aria-expanded", "false");
      }
    });

    let timer: number | undefined;
    input?.addEventListener("input", () => {
      clearTimeout(timer);
      timer = window.setTimeout(async () => {
        const q = input.value.trim();
        if (!q || !pagefind) {
          results.hidden = true;
          results.innerHTML = "";
          return;
        }
        const { results: hits } = await pagefind.search(q);
        const top = await Promise.all(hits.slice(0, 8).map((h: any) => h.data()));
        results.innerHTML = top
          .map(
            (d: any) =>
              `<a href="${d.url}" class="search-hit"><strong>${d.meta.title ?? d.url}</strong><span>${d.excerpt}</span></a>`,
          )
          .join("");
        results.hidden = false;
      }, 150);
    });
  }
</script>

<style>
  .search-box {
    position: relative;
  }
  .search-toggle {
    background: transparent;
    border: 0;
    color: white;
    cursor: pointer;
    padding: 0.4rem;
    border-radius: 3px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .search-toggle:hover,
  .search-toggle[aria-expanded="true"] {
    background: rgba(255, 255, 255, 0.12);
  }
  .search-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    background: white;
    color: var(--c-text);
    border-radius: 4px;
    box-shadow: var(--shadow-md);
    z-index: 100;
    padding: 0.5rem;
    min-width: 320px;
  }
  #search-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--c-border);
    border-radius: 3px;
    font-family: inherit;
    font-size: 0.95rem;
  }
  .search-results {
    margin-top: 0.5rem;
    max-height: 60vh;
    overflow-y: auto;
  }
  :global(.search-hit) {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--c-text);
    text-decoration: none;
    border-bottom: 1px solid var(--c-border);
  }
  :global(.search-hit:hover) {
    background: var(--c-bg-soft);
  }
  :global(.search-hit strong) {
    display: block;
  }
  :global(.search-hit span) {
    font-size: 0.85rem;
    color: var(--c-muted);
  }
</style>
