---
import { t } from "@lib/i18n";

interface Props {
  lang: string;
}
const { lang } = Astro.props;

const products = [
  { id: "altinn-studio/v8", labelKey: "product_studio", fallback: "Altinn Studio" },
  { id: "authorization", labelKey: "product_authorization", fallback: "Autorisasjon" },
  { id: "dialogporten", labelKey: "product_dialogporten", fallback: "Dialogporten" },
  { id: "broker", labelKey: "product_broker", fallback: "Broker" },
  { id: "events", labelKey: "product_events", fallback: "Events" },
  { id: "correspondence", labelKey: "product_correspondence", fallback: "Correspondence" },
  { id: "notifications", labelKey: "product_notifications", fallback: "Notifications" },
];
---

<div class="product-switcher">
  <button
    type="button"
    class="nav-link product-toggle"
    aria-haspopup="true"
    aria-expanded="false"
    aria-controls="product-menu"
  >
    <span>{t("product", lang, "produkt")}</span>
    <svg class="caret" width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
      <path d="M0 0l5 6 5-6z" fill="currentColor" />
    </svg>
  </button>
  <div id="product-menu" class="product-menu" hidden>
    {products.map((p) => (
      <a class="product-item" href={`/${lang}/${p.id}/`}>
        {t(p.labelKey, lang, p.fallback)}
      </a>
    ))}
  </div>
</div>

<script>
  const root = document.querySelector(".product-switcher") as HTMLElement | null;
  if (root) {
    const btn = root.querySelector(".product-toggle") as HTMLButtonElement;
    const menu = root.querySelector(".product-menu") as HTMLElement;
    function close() {
      menu.hidden = true;
      btn.setAttribute("aria-expanded", "false");
    }
    function toggle() {
      const open = !menu.hidden;
      if (open) {
        close();
      } else {
        menu.hidden = false;
        btn.setAttribute("aria-expanded", "true");
      }
    }
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle();
    });
    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  }
</script>

<style>
  .product-switcher {
    position: relative;
  }
  .product-toggle {
    background: transparent;
    border: 0;
    color: white;
    cursor: pointer;
    font-family: inherit;
    font-size: 1rem;
    padding: 0.4rem 0.2rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border-bottom: 2px solid transparent;
    text-transform: lowercase;
  }
  .product-toggle:hover,
  .product-toggle[aria-expanded="true"] {
    border-bottom-color: var(--c-altinn-blue-light);
  }
  .caret {
    margin-left: 0.15rem;
    flex-shrink: 0;
  }
  .product-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    background: white;
    color: var(--c-text);
    min-width: 220px;
    border-radius: 4px;
    box-shadow: var(--shadow-md);
    z-index: 100;
    padding: 0.5rem 0;
  }
  .product-item {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--c-text);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .product-item:hover {
    background: var(--c-bg-soft);
  }
</style>
