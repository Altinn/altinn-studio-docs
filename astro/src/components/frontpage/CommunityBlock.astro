---
import { t } from "@lib/i18n";

interface Props {
  lang: string;
}
const { lang } = Astro.props;
---

<div class="caseblock">
  <div class="caseblock-image">
    <img src="/images/community.svg" alt="" />
  </div>
  <div class="caseblock-content">
    <h2>{t("caseblock-title", lang, "Vi bygger Altinn sammen")}</h2>
    <p set:html={t("caseblock-description", lang, "Samarbeid, del og lær av andre etater. Alt vi gjør er åpen kildekode på GitHub, og vi setter stor pris på dine tilbakemeldinger og bidrag!")} />
    <a class="caseblock-btn" href={`/${lang}/community/`}>
      {t("caseblock-link", lang, "Community")}
    </a>
  </div>
</div>

<style>
  .caseblock {
    background: var(--c-bg-soft);
    margin: 1rem 0 3rem 0;
    padding: 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .caseblock {
      grid-template-columns: minmax(160px, 320px) 1fr;
      gap: 3rem;
    }
  }
  .caseblock-image {
    text-align: center;
  }
  .caseblock-image img {
    max-width: 240px;
    width: 100%;
    height: auto;
  }
  .caseblock-content h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
    font-weight: 600;
  }
  .caseblock-content p {
    margin: 0 0 1.5rem 0;
    font-size: 0.95rem;
    color: var(--c-text);
  }
  .caseblock-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    border: 2px solid var(--c-altinn-blue);
    color: var(--c-altinn-blue);
    background: transparent;
    text-decoration: none;
    font-size: 1.1rem;
    transition: background 0.15s, color 0.15s;
  }
  .caseblock-btn:hover {
    background: var(--c-altinn-blue);
    color: white;
    text-decoration: none;
  }
</style>
