---
import type { NavNode } from "@lib/nav-tree";

interface Props {
  node: NavNode;
  pathname: string;
}

const { node, pathname } = Astro.props;
if (node.hidden) {
  // ikke render
}

const isActive = pathname === node.url;
const isAncestor = pathname.startsWith(node.url) && pathname !== node.url;
const isOpen = node.alwaysopen || isActive || isAncestor;
const hasChildren = node.children && node.children.length > 0;
---

{!node.hidden && (
  <li class:list={["dd-item", { parent: hasChildren, active: isActive }]}>
    <a href={node.url} class:list={[{ active: isActive, ancestor: isAncestor }]}>
      {node.pre && <span set:html={node.pre} />}
      <span class="link-title">{node.linktitle}</span>
      {node.post && <span set:html={node.post} />}
      {node.titleSup && <sup>{node.titleSup}</sup>}
      {hasChildren && (
        <span class="caret" aria-hidden="true">{isOpen ? "▾" : "▸"}</span>
      )}
    </a>
    {hasChildren && isOpen && (
      <ul>
        {node.children.map((c) => <Astro.self node={c} pathname={pathname} />)}
      </ul>
    )}
  </li>
)}

<style>
  .dd-item {
    list-style: none;
  }
  .dd-item a {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.6rem;
    color: var(--c-text);
    text-decoration: none;
    border-radius: 3px;
  }
  .dd-item a:hover {
    background: var(--c-bg-soft);
  }
  .dd-item a.active {
    background: var(--c-altinn-blue);
    color: white;
    font-weight: 600;
  }
  .dd-item a.ancestor {
    font-weight: 600;
  }
  .dd-item ul {
    list-style: none;
    padding-left: 1rem;
    margin: 0;
    border-left: 1px solid var(--c-border);
  }
  .caret {
    margin-left: auto;
    color: var(--c-muted);
  }
  .link-title {
    flex: 1;
  }
</style>
