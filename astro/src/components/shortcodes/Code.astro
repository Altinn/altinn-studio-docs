---
interface Props {
  language?: string;
  title?: string;
}
const { language, title } = Astro.props;
---

<div class="code-block">
  {title && <div class="code-title">{title}</div>}
  <pre class:list={[language ? `language-${language}` : ""]}><slot /></pre>
</div>

<style>
  .code-block {
    margin: 1rem 0;
  }
  .code-title {
    background: var(--c-altinn-blue);
    color: white;
    padding: 0.4rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    border-radius: 4px 4px 0 0;
  }
  .code-block pre {
    margin: 0;
    border-radius: 0 0 4px 4px;
  }
  .code-title + pre {
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }
</style>
