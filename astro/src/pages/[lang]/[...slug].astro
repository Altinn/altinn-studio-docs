---
import { getCollection, render } from "astro:content";
import DocsLayout from "@layouts/DocsLayout.astro";
import OpenApiViewer from "@components/OpenApiViewer.astro";
import { site } from "@lib/site";

export async function getStaticPaths() {
  const all = await getCollection("docs");
  const out: any[] = [];
  for (const entry of all) {
    // entry.id er stien relativt til src/content/docs/, uten ekstension
    // f.eks. "nb/altinn-studio/v10/index" eller "nb/altinn-studio/v10/app".
    // Astros content layer lowercaser ider, så vi gjør ingen ekstra normalisering.
    const id = entry.id;
    const firstSlash = id.indexOf("/");
    if (firstSlash < 0) continue;
    const lang = id.slice(0, firstSlash);
    let rest = id.slice(firstSlash + 1);
    if (!site.languages.includes(lang)) continue;
    if (rest === "" || rest === "index") continue; // håndteres av [lang]/index.astro
    if (rest.endsWith("/index")) rest = rest.slice(0, -"/index".length);
    // Hopp over hidden og headless. Headless-pages er fragmenter Hugo
    // bruker for å gruppere assets/data uten egen URL.
    if (entry.data.hidden === true) continue;
    if (entry.data.headless === true) continue;
    if (process.env.ASTRO_SKIP_DRAFTS === "1" && entry.data.draft === true) continue;
    out.push({
      params: { lang, slug: rest },
      props: { entry },
    });
  }
  return out;
}

const { entry } = Astro.props;
const { lang } = Astro.params;
const { Content, headings } = await render(entry);
const data = entry.data;
const slug = entry.id;

// Sjekk om innholdet inneholder Mermaid eller Swagger for lazy-loading
const body = entry.body ?? "";
const needsMermaid = /<Mermaid\b/.test(body) || /class="mermaid"/.test(body);
const hasSwagger = /<Swagger(Load|DisplayOperation|DisplayEntity)\b/.test(body) || /<DialogportenSwaggerSelector\b/.test(body);
const isOpenApi = data.type === "openapi" && typeof data.spec === "string";
---

<DocsLayout
  title={data.title}
  description={data.description}
  lang={lang!}
  slug={slug}
  headings={headings}
  origPath={data._origPath}
  editURL={data._editURL}
  needsMermaid={needsMermaid}
  hasSwagger={hasSwagger}
  titleSup={data.titleSup}
  subTitle={data.SubTitle}
>
  <Content />
  {isOpenApi && <OpenApiViewer spec={data.spec} />}
</DocsLayout>
